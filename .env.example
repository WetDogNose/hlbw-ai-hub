# The base URL of your application. Used for generating QR codes.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# PostgreSQL database URL for Prisma (Cloud SQL Direct Connection via IP)
DATABASE_URL=

# Your Gemini API key. You can get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Authentication (OAuth Providers & NextAuth)
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft / Azure AD OAuth (https://portal.azure.com → App registrations)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# Apple Sign-In (https://developer.apple.com)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Email Notification System (Admin Approvals)
# -----------------------------------------------------------------------------
# Configure your SMTP provider (e.g. Gmail App Passwords, SendGrid, Mailgun)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# The email address that should receive requests to approve new users
ADMIN_EMAIL=

# -----------------------------------------------------------------------------
# Google AdSense
# -----------------------------------------------------------------------------
# Your AdSense Publisher ID (e.g., ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_PUB_ID=

# Production PostgreSQL Read-Only user for the MCP service
MCP_DATABASE_URL=
