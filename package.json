{
  "name": "hlbw-ai-hub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev": "node scripts/pre-flight.js",
    "genkit:dev": "genkit start -- npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "node scripts/memory-tracker.js \"jest --passWithNoTests\"",
    "test:watch": "jest --watch",
    "test:db": "node scripts/memory-tracker.js \"node scripts/test-db.js\"",
    "test:types": "node scripts/memory-tracker.js \"tsc --noEmit\"",
    "db:migrate-urls": "node scripts/migrate-image-urls.js",
    "test:security": "node scripts/memory-tracker.js \"npm audit --audit-level=critical && secretlint \\\"**/*\\\"\"",
    "test:coverage": "node scripts/generate-coverage.js",
    "mcp:testing": "node scripts/mcp-tester.mjs",
    "mcp:logging": "node scripts/mcp-logging-server.mjs",
    "mcp:refresh": "npm run toolchain-doctor -- --mcp-refresh",
    "secretlint": "secretlint \"**/*\"",
    "bootstrap": "node scripts/bootstrap.mjs",
    "toolchain-doctor": "node scripts/toolchain-doctor.js",
    "sync-agents": "node scripts/sync-agent-configs.js",
    "auto-doc": "node scripts/auto-document.js",
    "monitor:memory": "node scripts/swarm/monitor-memory.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.12",
    "@auth/prisma-adapter": "^2.11.1",
    "@genkit-ai/google-genai": "^1.30.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/logging": "^11.2.1",
    "@google-cloud/opentelemetry-cloud-trace-exporter": "^3.0.0",
    "@google-cloud/storage": "^7.19.0",
    "@google-cloud/vertexai": "^1.9.0",
    "@google/adk": "^0.5.0",
    "@modelcontextprotocol/server-postgres": "^0.6.2",
    "@prisma/client": "6.4.1",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.9.0",
    "@types/qrcode": "^1.5.6",
    "@vercel/otel": "^2.1.1",
    "browser-image-compression": "^2.0.2",
    "cross-spawn": "^7.0.6",
    "date-fns": "^4.1.0",
    "genkit": "^1.30.1",
    "glob": "^13.0.6",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "nodemailer": "^8.0.2",
    "prisma": "6.4.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-image-crop": "^11.0.10",
    "sharp": "^0.34.5",
    "stripe": "^20.4.1",
    "swr": "^2.4.1"
  },
  "overrides": {
    "@google/adk": {
      "@opentelemetry/exporter-logs-otlp-http": "$@opentelemetry/exporter-logs-otlp-http",
      "@opentelemetry/exporter-trace-otlp-http": "$@opentelemetry/exporter-trace-otlp-http",
      "@opentelemetry/sdk-node": "$@opentelemetry/sdk-node",
      "@opentelemetry/api": "$@opentelemetry/api",
      "@opentelemetry/resources": "$@opentelemetry/resources"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-security": "^4.0.0",
    "googleapis": "^171.4.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.3.3",
    "node-mocks-http": "^1.17.2",
    "secretlint": "^11.3.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
