FROM node:20-slim

WORKDIR /workspace

# Install system dependencies
RUN apt-get update && apt-get install -y git curl jq && rm -rf /var/lib/apt/lists/*

# Copy package descriptors to root so they install into /node_modules
# Node module resolution will climb up from /workspace to /node_modules
COPY package.json package-lock.json* /
RUN npm ci || npm install

# We do not copy the whole repo because the runtime will volume-mount the workspace

# Command is overridden by MCP run_container tool
