generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  role            String           @default("USER")
  isApproved      Boolean          @default(false)
  isTestUser      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  lastLogin       DateTime?
  oauthProvider   String?
  accounts        Account[]
  sessions        Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AISetting {
  id                String   @id @default(cuid())
  isActive                    Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  
  // Pipeline Mode: "SINGLE_PASS" or "THREE_STAGE"
  pipelineMode                String   @default("THREE_STAGE")
  generatedSinglePassPrompt   String   @default("")
  
  // Image Preprocessing
  imageCompressionEnabled     Boolean  @default(true)
  imageMaxResolution          Int      @default(2048)
  imageCompressionQuality     Int      @default(80)
  
  // Deduplication
  deduplicationEnabled        Boolean  @default(true)
  deduplicationPromptTemplate String   @default("")

  // Pipeline Parameters
  paddingPercentage           Float    @default(5.0)
  maxOutputTokens             Int      @default(8192)
  topP                        Float    @default(1.0)
  topK                        Int      @default(40)

  // Stage 1 (Spatial)
  stage1Enabled               Boolean  @default(false)
  stage1Model                 String   @default("gemini-2.5-flash")
  stage1SystemInstruction     String   @default("")
  stage1Prompt                String
  stage1Temperature           Float    @default(0.0)

  // Stage 2 (Vision)
  stage2Model                 String   @default("gemini-2.5-flash")
  stage2SystemInstruction     String   @default("")
  stage2Prompt                String
  stage2Temperature           Float    @default(0.4)
}

model AppearanceSetting {
  id                String   @id @default(cuid())
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())

  // Base / Backgrounds
  bgPrimary         String   @default("#0f172a") 
  bgSecondary       String   @default("#1e293b") 
  bgTertiary        String   @default("#334155")
  customHtmlBackground String @default("")
  customHtmlBackgroundEnabled Boolean @default(true)

  // Typography
  textPrimary       String   @default("#f8fafc")
  textSecondary     String   @default("#cbd5e1")
  textMuted         String   @default("#94a3b8")
  fontFamily        String   @default("Inter, sans-serif") 
  titleGradientStart String  @default("#60a5fa") 
  titleGradientEnd   String  @default("#c084fc") 

  // Accents / Buttons
  accentColor       String   @default("#3b82f6") 
  accentHover       String   @default("#2563eb")

  // Status / Alerts
  dangerColor       String   @default("#ef4444")
  successColor      String   @default("#10b981")
  warningColor      String   @default("#f59e0b")
  infoColor         String   @default("#3b82f6")
  purpleColor       String   @default("#a855f7")

  // Structural & Layout
  borderColor       String   @default("#334155")
  borderRadiusSm    String   @default("4px")
  borderRadiusMd    String   @default("8px")
  borderRadiusLg    String   @default("16px")
  borderRadiusFull  String   @default("9999px")
}

model SystemSetting {
  id                  String   @id @default(cuid())
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  autoApproveNewUsers Boolean  @default(false)
}

// --- Paperclip.ing Orchestration Models ---

model Organization {
  id          String   @id @default(cuid())
  name        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  agents      AgentPersona[]
  goals       Goal[]
}

model AgentPersona {
  id             String       @id @default(cuid())
  name           String
  role           String       // e.g. "CTO", "QA", "DEV"
  status         String       @default("IDLE") // IDLE, RUNNING, PAUSED
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  issues         Issue[]      @relation("AssignedAgent")
  ledgers        BudgetLedger[]
}

model Goal {
  id             String       @id @default(cuid())
  description    String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  issues         Issue[]
}

model Thread {
  id        String   @id @default(cuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  issues    Issue[]
}

model Issue {
  id               String          @id @default(cuid())
  // Pass 4: unified Task/Issue model — see docs/re-arch/pass-04-result.md
  title            String?
  instruction      String
  status           String          @default("pending") // pending, in_progress, blocked, completed, failed, cancelled, needs_human
  priority         Int             @default(5)
  dependencies     String[]        @default([])
  blockedBy        String[]        @default([])
  agentCategory    String?
  isolationId      String?
  assignedAgentLabel String?
  startedAt        DateTime?
  completedAt      DateTime?
  metadata         Json            @default("{}")
  threadId         String
  thread           Thread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  assignedAgentId  String?
  assignedAgent    AgentPersona?   @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  goalId           String?
  goal             Goal?           @relation(fields: [goalId], references: [id])
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  parentRelations  IssueRelation[] @relation("ParentIssue")
  childRelations   IssueRelation[] @relation("ChildIssue")
  ledgers          BudgetLedger[]
  graphState       TaskGraphState?
}

model IssueRelation {
  id            String   @id @default(cuid())
  parentIssueId String
  childIssueId  String
  parentIssue   Issue    @relation("ParentIssue", fields: [parentIssueId], references: [id], onDelete: Cascade)
  childIssue    Issue    @relation("ChildIssue", fields: [childIssueId], references: [id], onDelete: Cascade)
  dependencyType String  @default("BLOCKS") // BLOCKS, RELATES_TO
}

model Routine {
  id             String   @id @default(cuid())
  cronExpression String
  taskPayload    String
  isActive       Boolean  @default(true)
  lastRunAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BudgetLedger {
  id            String       @id @default(cuid())
  agentId       String
  agent         AgentPersona @relation(fields: [agentId], references: [id], onDelete: Cascade)
  issueId       String?
  issue         Issue?       @relation(fields: [issueId], references: [id], onDelete: SetNull)
  tokensUsed    Int
  cost          Float        @default(0.0)
  timestamp     DateTime     @default(now())
}

model WebhookConfig {
  id          String   @id @default(cuid())
  name        String
  endpoint    String
  secret      String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Pass 7: single episodic memory store (decisions.md D1 — Postgres + pgvector).
// `taskId` is a loose scalar reference to `Issue.id`; no FK because some episodes
// aren't task-scoped (global discoveries, bootstrap context, etc.).
model MemoryEpisode {
  id            String                       @id @default(cuid())
  taskId        String?
  kind          String
  agentCategory String?
  content       Json
  summary       String
  embedding     Unsupported("vector(768)")?
  createdAt     DateTime                     @default(now())

  @@index([taskId])
  @@index([kind])
  @@index([createdAt])
  @@map("memory_episode")
}

// Pass 8: StateGraph runtime persistence. One row per Issue that is being
// driven by the in-house graph runtime. `currentNode` + `status` form the
// atomic progress marker; `context` is the running state object each node
// reads/writes; `history` is an append-only log of HistoryEntry records.
// Every mutation MUST be wrapped in `prisma.$transaction` with a `FOR UPDATE`
// row lock acquired via $queryRaw — see lib/orchestration/graph/StateGraph.ts.
model TaskGraphState {
  id               String           @id @default(cuid())
  issueId          String           @unique
  issue            Issue            @relation(fields: [issueId], references: [id], onDelete: Cascade)
  currentNode      String
  status           GraphStateStatus @default(running)
  context          Json             @default("{}")
  history          Json             @default("[]")
  interruptReason  String?
  lastTransitionAt DateTime         @default(now())
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status])
  @@index([currentNode])
  @@map("task_graph_state")
}

enum GraphStateStatus {
  running
  paused
  interrupted
  completed
  failed
}

// Pass 23 — UI-editable runtime knobs (decisions.md D5 — user-gated migration).
// Loader: `lib/orchestration/runtime-config.ts`. Write routes are admin-gated
// via `requireAdmin()` and audited via `recordAdminAction()`. Keys are an
// enumerated set (see `RuntimeConfigKey`).
model RuntimeConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("runtime_config")
}
