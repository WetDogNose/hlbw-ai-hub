generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  ext_expires_in    Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String?          @unique
  emailVerified   DateTime?
  image           String?
  role            String           @default("USER")
  isApproved      Boolean          @default(false)
  isTestUser      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  lastLogin       DateTime?
  oauthProvider   String?
  accounts        Account[]
  sessions        Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AISetting {
  id                String   @id @default(cuid())
  isActive                    Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  
  // Pipeline Mode: "SINGLE_PASS" or "THREE_STAGE"
  pipelineMode                String   @default("THREE_STAGE")
  generatedSinglePassPrompt   String   @default("")
  
  // Image Preprocessing
  imageCompressionEnabled     Boolean  @default(true)
  imageMaxResolution          Int      @default(2048)
  imageCompressionQuality     Int      @default(80)
  
  // Deduplication
  deduplicationEnabled        Boolean  @default(true)
  deduplicationPromptTemplate String   @default("")

  // Pipeline Parameters
  paddingPercentage           Float    @default(5.0)
  maxOutputTokens             Int      @default(8192)
  topP                        Float    @default(1.0)
  topK                        Int      @default(40)

  // Stage 1 (Spatial)
  stage1Enabled               Boolean  @default(false)
  stage1Model                 String   @default("gemini-2.5-flash")
  stage1SystemInstruction     String   @default("")
  stage1Prompt                String
  stage1Temperature           Float    @default(0.0)

  // Stage 2 (Vision)
  stage2Model                 String   @default("gemini-2.5-flash")
  stage2SystemInstruction     String   @default("")
  stage2Prompt                String
  stage2Temperature           Float    @default(0.4)
}

model AppearanceSetting {
  id                String   @id @default(cuid())
  isActive          Boolean  @default(false)
  createdAt         DateTime @default(now())

  // Base / Backgrounds
  bgPrimary         String   @default("#0f172a") 
  bgSecondary       String   @default("#1e293b") 
  bgTertiary        String   @default("#334155")
  customHtmlBackground String @default("")
  customHtmlBackgroundEnabled Boolean @default(true)

  // Typography
  textPrimary       String   @default("#f8fafc")
  textSecondary     String   @default("#cbd5e1")
  textMuted         String   @default("#94a3b8")
  fontFamily        String   @default("Inter, sans-serif") 
  titleGradientStart String  @default("#60a5fa") 
  titleGradientEnd   String  @default("#c084fc") 

  // Accents / Buttons
  accentColor       String   @default("#3b82f6") 
  accentHover       String   @default("#2563eb")

  // Status / Alerts
  dangerColor       String   @default("#ef4444")
  successColor      String   @default("#10b981")
  warningColor      String   @default("#f59e0b")
  infoColor         String   @default("#3b82f6")
  purpleColor       String   @default("#a855f7")

  // Structural & Layout
  borderColor       String   @default("#334155")
  borderRadiusSm    String   @default("4px")
  borderRadiusMd    String   @default("8px")
  borderRadiusLg    String   @default("16px")
  borderRadiusFull  String   @default("9999px")
}

model SystemSetting {
  id                  String   @id @default(cuid())
  isActive            Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  autoApproveNewUsers Boolean  @default(false)
}
